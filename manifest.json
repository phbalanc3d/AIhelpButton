{
    "manifest_version": 3,
    "name": "AZ Chat Bot",
    "version": "0.1",
    "author": "Pachi Honhaga",
    "description": "Helps to solve AZ problemset using AI Chat Bot",
    "host_permissions": [
      "https://maang.in/*"
    ],
    "permissions": [
      "storage",
      "scripting",
      "activeTab"
    ],
    "content_scripts": [
      {
        "matches": [
          "https://maang.in/*"
        ],
        "js": [
          "content.js",
          "marked.min.js"
          
        ],
        "run_at": "document_idle"
      }
    ],
    "background": {
      "service_worker": "background.js"
    },
    
    "action": {
      "default_icon": {
        "16": "assets/icon.png",
        "24": "assets/icon.png",
        "32": "assets/icon.png"
      },
      "default_popup": "index.html",
      "default_title": "AZ Chat Bot"
    }
  }